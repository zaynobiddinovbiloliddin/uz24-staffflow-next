# ==========================================
# DATABASE — PostgreSQL (MAJBURIY)
# ==========================================
# Local Docker:
DATABASE_URL="postgresql://uz24user:uz24pass_change_me@localhost:5432/uz24staffflow"

# Supabase:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# Neon (bepul serverless):
# DATABASE_URL="postgresql://[USER]:[PASSWORD]@[HOST]/[DB]?sslmode=require"

# Railway:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/railway"

# ==========================================
# DOCKER POSTGRES (docker-compose uchun)
# ==========================================
POSTGRES_DB="uz24staffflow"
POSTGRES_USER="uz24user"
POSTGRES_PASSWORD="CHANGE_ME_strong_password_here"

# ==========================================
# NEXTAUTH (MAJBURIY)
# ==========================================
NEXTAUTH_URL="http://localhost:3000"
# Generatsiya: openssl rand -base64 32
NEXTAUTH_SECRET="CHANGE_ME_use_openssl_rand_base64_32_output"

# ==========================================
# NODE ENV
# ==========================================
NODE_ENV="development"

# ==========================================
# TELEGRAM BOT (ixtiyoriy)
# ==========================================
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
TELEGRAM_BACKUP_CHAT_ID="your_channel_id"
