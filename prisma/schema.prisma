generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// ENUMS — PostgreSQL native enums
// ==========================================

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum EquipmentStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
  BROKEN
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

enum PayrollStatus {
  PENDING
  PAID
}

enum ContactType {
  DRIVER
  REPORTER
  TECHNICIAN
  OTHER
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String  @id @default(cuid())
  fullName     String  @db.VarChar(100)
  username     String  @unique @db.VarChar(50)
  password     String
  role         Role    @default(EMPLOYEE)
  position     String? @db.VarChar(100)
  phone        String? @db.VarChar(20)
  telegramId   String? @db.VarChar(50)
  avatar       String?
  isActive       Boolean  @default(true)
  departmentId   String?
  portfolioLinks String[] @default([])

  department    Department?    @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  assignedTasks Task[]         @relation("AssignedTo")
  createdTasks  Task[]         @relation("CreatedBy")
  schedules     Schedule[]
  payrolls      Payroll[]
  reports       Report[]
  notifications Notification[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([role])
  @@index([departmentId])
  @@index([isActive])

  dailyStatuses  DailyStatus[]
  filmingCreated FilmingEntry[] @relation("CreatedFilming")
  contacts       Contact[]      @relation("CreatedContacts")
}

model Department {
  id          String  @id @default(cuid())
  name        String  @unique @db.VarChar(100)
  description String? @db.VarChar(500)
  color       String  @default("#3b82f6") @db.VarChar(7)

  users User[]
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Task {
  id           String       @id @default(cuid())
  title        String       @db.VarChar(200)
  description  String?      @db.Text
  status       TaskStatus   @default(PENDING)
  priority     TaskPriority @default(MEDIUM)
  deadline     DateTime?
  cancelReason String?      @db.VarChar(500)
  assignedToId String?
  createdById  String
  departmentId String?

  assignedTo User?       @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdBy  User        @relation("CreatedBy", fields: [createdById], references: [id])
  department Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assignedToId])
  @@index([createdById])
  @@index([departmentId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([status, departmentId])
}

model Schedule {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  startTime String   @db.VarChar(5)
  endTime   String   @db.VarChar(5)
  shiftType String   @default("Kunduzgi") @db.VarChar(20)
  note      String?  @db.VarChar(500)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([date])
}

model Equipment {
  id           String          @id @default(cuid())
  name         String          @db.VarChar(100)
  type         String          @db.VarChar(100)
  serialNumber String?         @unique @db.VarChar(100)
  status       EquipmentStatus @default(AVAILABLE)
  assignedToId String?
  condition    String?         @db.VarChar(200)
  purchaseDate DateTime?
  notes        String?         @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
}

model Vehicle {
  id           String        @id @default(cuid())
  name         String        @db.VarChar(100)
  plateNumber  String        @unique @db.VarChar(20)
  type         String        @db.VarChar(100)
  status       VehicleStatus @default(AVAILABLE)
  assignedToId String?
  mileage      Int?
  fuelType     String?       @db.VarChar(50)
  notes        String?       @db.VarChar(500)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([assignedToId])
}

model Payroll {
  id          String        @id @default(cuid())
  userId      String
  month       Int           @db.SmallInt
  year        Int           @db.SmallInt
  baseSalary  Decimal       @db.Decimal(12, 2)
  bonus       Decimal       @default(0) @db.Decimal(12, 2)
  deductions  Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount Decimal       @db.Decimal(12, 2)
  status      PayrollStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?       @db.VarChar(500)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, month, year])
  @@index([userId])
  @@index([status])
  @@index([year, month])
}

model Report {
  id      String  @id @default(cuid())
  title   String  @db.VarChar(200)
  content String? @db.Text
  fileUrl String?
  type    String  @default("general") @db.VarChar(50)
  userId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
}

model Notification {
  id      String  @id @default(cuid())
  title   String  @db.VarChar(200)
  message String  @db.Text
  type    String  @default("info") @db.VarChar(50)
  isRead  Boolean @default(false)
  userId  String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@index([userId, isRead])
}

model AuditLog {
  id       String  @id @default(cuid())
  action   String  @db.VarChar(50)
  entity   String  @db.VarChar(50)
  entityId String? @db.VarChar(30)
  details  String? @db.Text
  userId   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([action])
  @@index([createdAt])
}

// I=Ishda, D=Dam, S=Safar, K=Kasallik, T=Ta'til, B=Boshqa, O=Otpusk
model DailyStatus {
  id     String   @id @default(cuid())
  userId String
  date   DateTime @db.Date
  status String   @db.VarChar(2)
  note   String?  @db.VarChar(300)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model FilmingEntry {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  title       String   @default("Tasvirga olish jadvali")
  approvedBy  String   @default("M. Safarov")
  createdById String

  createdBy User              @relation("CreatedFilming", fields: [createdById], references: [id])
  operators FilmingOperator[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([createdById])
}

model FilmingOperator {
  id               String  @id @default(cuid())
  filmingEntryId   String
  cameraNumber     String
  exitTime         String
  operatorNames    String[]
  eventLocation    String
  eventDescription String?
  reporterNames    String[]
  equipment        String  @default("HD jamlanmasi, mikrofon, chiroq, avtotransport")
  sortOrder        Int     @default(0)

  filmingEntry FilmingEntry @relation(fields: [filmingEntryId], references: [id], onDelete: Cascade)
}

model Contact {
  id               String      @id @default(cuid())
  type             ContactType
  fullName         String      @db.VarChar(100)
  phone            String      @db.VarChar(30)
  vehicleInfo      String?     @db.VarChar(100)
  telegramUsername String?     @db.VarChar(50)
  notes            String?     @db.VarChar(500)
  isActive         Boolean     @default(true)
  createdById      String

  createdBy User @relation("CreatedContacts", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isActive])
  @@index([createdById])
}
